* Test basic versions of converting from integers to floating point values
*/


fn i32_plus_f32(x:i32, f:f32) -> f32 {
	ret x + f;
}


fn i32_plus_f64(x:i32, f:f64) -> f64 {
	ret x + f;
}


fn i64_plus_f64(x:i64, f:f64) -> f64 {
	ret x + f;
}


